    "globals": "^16.4.0",
    "jsdom": "^27.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.10",
    "vitest": "^3.2.4",
    "@vitejs/plugin-react": "^5.0.4"
  }
