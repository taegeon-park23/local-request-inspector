    "lint:scripts": "eslint \"scripts/**/*.mjs\"",
    "typecheck": "tsc --project tsconfig.json",
    "test": "npm run test:node && npm run test:ui",
    "test:node": "node scripts/run-node-seam-tests.mjs",
    "test:ui": "node scripts/run-vitest.mjs run",
    "bootstrap:storage": "node -e \"require('./storage').bootstrapPersistence()\""
  },
